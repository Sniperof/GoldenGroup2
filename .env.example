# ============================================================
# Golden CRM — Environment Variables Template
# ============================================================
# 1. انسخ هذا الملف وسمّه .env
# 2. عبّئ القيم الفعلية — لا ترفع الملف على GitHub أبداً
# ============================================================

# ── قاعدة البيانات ──────────────────────────────────────────
# إذا استخدمت postgres من docker-compose استخدم:
#   DATABASE_URL=postgresql://golden:PASSWORD@db:5432/golden_crm
# إذا كانت قاعدة البيانات خارجية ضع عنوانها مباشرة:
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# ── PostgreSQL (خاص بـ docker-compose فقط) ─────────────────
# يُستخدم فقط عندما تعتمد على حاوية db الداخلية
POSTGRES_DB=golden_crm
POSTGRES_USER=golden
POSTGRES_PASSWORD=change_me_strong_password

# ── بيئة التشغيل ────────────────────────────────────────────
NODE_ENV=production

# ── JWT Secret (مفتاح تشفير الجلسات) ───────────────────────
# أنشئ مفتاحاً عشوائياً: openssl rand -hex 32
JWT_SECRET=your_super_secret_key_here

# ── بورت التطبيق على الهوست (shared nginx يبروكسي له) ──────
APP_PORT=3880

# ── CORS (نطاقات مسموح بها من الفرونتإند) ──────────────────
# مثال: CORS_ORIGINS=https://crm.example.com,https://www.example.com
CORS_ORIGINS=

# ── مسار ملفات الرفع (اختياري) ─────────────────────────────
# الافتراضي /app/uploads داخل الحاوية — غيّره إن أردت تخصيصه
# UPLOADS_DIR=/app/uploads
