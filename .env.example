# ============================================================
# Golden CRM — Environment Variables Template
# ============================================================
# 1. انسخ هذا الملف وسمّه .env.development (أو .env)
# 2. عبّئ القيم الفعلية — لا ترفع الملف على GitHub أبداً
# =========================================================

# قاعدة البيانات
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# بيئة التشغيل
NODE_ENV=development

# عنوان API للفرونتإند
VITE_API_URL=http://localhost:3000

# JWT Secret (مفتاح تشفير الجلسات)
JWT_SECRET=your_super_secret_key_here
